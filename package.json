{
  "name": "ai-content-pipeline",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @aicp/api run start:dev",
    "dev:worker": "npm --workspace @aicp/worker run start:dev",
    "dev:dashboard": "npm --workspace @aicp/dashboard run dev",
    "build:api": "npm --workspace @aicp/api run build",
    "build:worker": "npm --workspace @aicp/worker run build",
    "build:dashboard": "npm --workspace @aicp/dashboard run build",
    "lint:workspaces": "npm run lint --workspaces",
    "lint:structure": "node scripts/check-code-shape.mjs",
    "lint": "npm run lint:workspaces && npm run lint:structure",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "vitest": "^2.1.8"
  }
}
