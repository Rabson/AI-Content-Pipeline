{
  "extends": "../../packages/shared-config/tsconfig/base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-docker/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/* 2.ts",
    "**/* 2.json"
  ]
}
