{
  "extends": "../../packages/shared-config/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "..",
    "paths": {
      "@worker/*": ["src/*"],
      "@api/*": ["../api/src/*"],
      "@aicp/api/*": ["../api/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../api/src/**/*.ts"],
  "exclude": ["dist", "node_modules", "../api/src/**/__tests__/**", "../api/test/**"]
}
