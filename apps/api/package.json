{
  "name": "@aicp/api",
  "version": "0.1.0",
  "private": true,
  "_moduleAliases": {
    "@api": "dist"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node -r module-alias/register dist/main.js",
    "start:dev": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.mts --dir ."
  },
  "dependencies": {
    "@aicp/auth-core": "0.1.0",
    "@aicp/backend-core": "0.1.0",
    "@aicp/contracts": "0.1.0",
    "@aicp/observability-core": "0.1.0",
    "@aicp/queue-contracts": "0.1.0",
    "@aicp/shared-config": "0.1.0",
    "@aicp/workflow-core": "0.1.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/client": "^7.4.2",
    "bullmq": "^5.0.0",
    "casbin": "^5.49.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "module-alias": "^2.2.3",
    "next-auth": "^4.24.13",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.5",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
