{
  "name": "@aicp/shared-config",
  "version": "0.1.0",
  "private": true,
  "main": "dist/env/readers.js",
  "types": "dist/env/readers.d.ts",
  "exports": {
    "./env/readers": {
      "types": "./dist/env/readers.d.ts",
      "default": "./dist/env/readers.js"
    }
  },
  "files": [
    "dist",
    "eslint",
    "tsconfig"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"env/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.mts --dir ."
  }
}
